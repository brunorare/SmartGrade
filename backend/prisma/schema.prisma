generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
    url      = env("DATABASE_URL")
  
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String

  tasks             Task[]            @relation("UserTasks")
  submissions       TaskSubmission[]
}

model Task {
  id Int @id @default(autoincrement())
  title String
  description String
  createdAt DateTime @default(now())
  deadline DateTime

  createdById Int
  createdBy   User     @relation("UserTasks", fields: [createdById], references: [id])

  parameters   ParameterSubmission[]
  submissions  TaskSubmission[]
}

model ParameterSubmission{
  id Int @id @default(autoincrement())
  title String
  weight Float
  description String
  createdAt   DateTime @default(now())

  taskId Int
  task Task @relation(fields: [taskId], references: [id])
}

model TaskSubmission {
  id Int @id @default(autoincrement())
  fileUrl String
  createdAt DateTime @default(now())

  aiFeedback String?
  aiGrade Float?

  taskId Int
  userId Int 

  task Task @relation(fields: [taskId], references: [id])
  user User @relation(fields: [userId], references: [id])
}
